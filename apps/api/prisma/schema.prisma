generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PARENT
  CHILD
  ADMIN
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum SubscriptionPlan {
  FREE
  MONTHLY
  ANNUAL
}

// Qué procesador de pago se usó
enum PaymentProvider {
  MERCADO_PAGO  // Para Argentina/LATAM
  LEMON_SQUEEZY // Para el resto del mundo
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id                String             @id @default(uuid())
  supabaseId        String             @unique @map("supabase_id")
  email             String             @unique
  displayName       String?            @map("display_name")
  avatarUrl         String?            @map("avatar_url")
  role              Role               @default(PARENT)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  
  children          ChildProfile[]
  subscription      Subscription?
  
  @@map("users")
}

model ChildProfile {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  name        String
  age         Int
  avatarId    String    @default("default") @map("avatar_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress    GameProgress[]
  sessions    GameSession[]
  
  @@map("children_profiles")
}

model Level {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  difficulty  Difficulty @default(EASY)
  category    String     @default("animals")
  worldId     String     @map("world_id")
  order       Int        @default(0)
  isPremium   Boolean    @default(false) @map("is_premium")
  isActive    Boolean    @default(true) @map("is_active")
  dataJson    Json       @map("data_json")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  
  world       World      @relation(fields: [worldId], references: [id])
  progress    GameProgress[]
  sessions    GameSession[]
  
  @@map("levels")
}

model World {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  iconUrl     String?  @map("icon_url")
  isPremium   Boolean  @default(false) @map("is_premium")
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  
  levels      Level[]
  
  @@map("worlds")
}

model GameProgress {
  id          String   @id @default(uuid())
  childId     String   @map("child_id")
  levelId     String   @map("level_id")
  stars       Int      @default(0)
  bestTime    Int?     @map("best_time")
  completed   Boolean  @default(false)
  attempts    Int      @default(0)
  unlockedAt  DateTime @default(now()) @map("unlocked_at")
  
  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  level       Level        @relation(fields: [levelId], references: [id])
  
  @@unique([childId, levelId])
  @@map("game_progress")
}

model GameSession {
  id          String   @id @default(uuid())
  childId     String   @map("child_id")
  levelId     String   @map("level_id")
  startedAt   DateTime @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  score       Int      @default(0)
  moves       Int      @default(0)
  timeSpent   Int      @default(0) @map("time_spent")
  completed   Boolean  @default(false)
  
  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  level       Level        @relation(fields: [levelId], references: [id])
  
  @@map("game_sessions")
}

// ─── SUSCRIPCIONES ─────────────────────────────────────────────────────────────
// Modelo agnóstico al proveedor de pago.
model Subscription {
  id                  String             @id @default(uuid())
  userId              String             @unique @map("user_id")

  // Qué proveedor se utilizó (null = plan FREE, sin proveedor)
  provider            PaymentProvider?

  // IDs del proveedor — Mercado Pago
  mpCustomerId        String?            @unique @map("mp_customer_id")
  mpSubscriptionId    String?            @unique @map("mp_subscription_id")
  mpPreapprovalPlanId String?            @map("mp_preapproval_plan_id")  // ID del plan en MP

  // IDs del proveedor externos
  lsCustomerId        String?            @unique @map("ls_customer_id")
  lsSubscriptionId    String?            @unique @map("ls_subscription_id")
  lsVariantId         String?            @map("ls_variant_id")           // Equivalente al Price ID

  // Estado y plan
  status              SubscriptionStatus @default(FREE)
  plan                SubscriptionPlan   @default(FREE)
  currentPeriodStart  DateTime?          @map("current_period_start")
  currentPeriodEnd    DateTime?          @map("current_period_end")
  cancelAtPeriodEnd   Boolean            @default(false) @map("cancel_at_period_end")
  
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("subscriptions")
}

// ─── WEBHOOKS ──────────────────────────────────────────────────────────────────
// Idempotency: registramos los eventos recibidos de cada proveedor para no procesarlos dos veces.
model WebhookEvent {
  id          String          @id @default(uuid())
  provider    PaymentProvider
  externalId  String          @map("external_id")  // ID único del evento en el proveedor
  type        String                                // e.g. "subscription_preapproval" / "subscription_updated"
  processed   Boolean         @default(false)
  payload     Json?                                 // Cuerpo completo del evento (útil para debugging)
  createdAt   DateTime        @default(now()) @map("created_at")
  
  @@unique([provider, externalId])
  @@map("webhook_events")
}
